<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F0F2F5">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/layout_main_cards_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <Button
                android:id="@+id/btn_add_extra_exercise"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="+ 진행 중 운동 즉석 추가"
                android:textSize="16sp"
                android:textColor="#2196F3"
                android:backgroundTint="#E3F2FD"
                android:layout_marginBottom="16dp"
                app:cornerRadius="8dp"/>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/tv_total_volume"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="오늘의 총 볼륨: 0.0 kg"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginVertical="12dp"/>

    <Button
        android:id="@+id/btn_show_timer"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="⏱ 1분 휴식 타이머 켜기"
        android:textSize="16sp"
        android:textColor="#333333"
        android:backgroundTint="#FFEB3B"/>

    <Button
        android:id="@+id/btn_calculate"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:text="완료 및 전체 볼륨 합산"
        android:textSize="18sp"
        android:backgroundTint="#2196F3"/>
</LinearLayout>